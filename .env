# OpenCage Geocoding API Key
# Get your API key from: https://opencagedata.com/
# Sign up for a free account and replace with your actual key
OPENCAGE_API_KEY=792b50d494e945bab9442e95fde1d09a

# Distance threshold (in km) to decide between hybrid vs local routing
# Routes longer than this will use flight + road (hybrid model)
# Routes shorter than this will use road-only routing with OSM
DISTANCE_THRESHOLD_KM=150.0

# Streamlit configuration (optional)
# Set to true to enable client analytics
CLIENT_ANALYTICS_ENABLED=false
